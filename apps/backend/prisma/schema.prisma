generator client {
  provider = "prisma-client-js"
}

// NOTE: The provider is set to "postgresql" for production (Railway).
// Local development uses SQLite via DATABASE_URL="file:./canvas-app.db" in .env.
// Prisma accepts the SQLite URL at runtime even with provider="postgresql", but
// `prisma db push` and `prisma migrate dev` may fail locally because they
// validate the provider against the connection string. To work around this:
//   1. Temporarily change provider to "sqlite" before running db push locally, OR
//   2. Use a local PostgreSQL instance and set DATABASE_URL accordingly.
// Do NOT commit a provider change to "sqlite" — production depends on "postgresql".
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     Boolean   @default(false)
  passwordHash      String
  name              String
  role              String    @default("researcher")
  plan              String    @default("free")
  stripeCustomerId  String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  resetTokenHash    String?
  resetTokenExpiry  DateTime?
  // Any JWT issued before this timestamp is rejected by the auth middleware.
  // Set on password reset, password change, and email change so stolen or
  // shared tokens don't outlive the credential change.
  sessionsInvalidAt DateTime?

  // Free-tier signups get a 14-day Pro trial. Auth middleware treats this
  // user as 'pro' until trialEndsAt elapses, then they revert to free
  // limits unless they've upgraded via Stripe in the meantime. Null means
  // no trial — that path is taken by users created before this column
  // existed (legacy / pre-2026 signups stay free unless they pay).
  trialEndsAt DateTime?

  // Pricing v2 grandfather flag. Users created before 2026-05-13 keep their
  // original $12/mo Pro tier billing — Stripe subscription continues at the
  // grandfathered Price ID. When false, new users land on the v2 ladder
  // (Pro $17, Researcher Pro $39, Team $49). This is read by the auth
  // middleware to gate Researcher Pro upsell visibility.
  legacyPricing Boolean @default(false)

  // Sprint F onboarding-v2 state. JSON: { currentStep, dismissedTooltips: [],
  // checklistComplete: [], startedAt }. Persisted server-side so the user
  // sees a coherent flow across devices. Null until first onboarding event.
  onboardingState       String?   @default("{}")
  onboardingCompletedAt DateTime?

  subscription     Subscription?
  codingCanvases   CodingCanvas[]
  dashboardAccess  DashboardAccess?
  repositories     ResearchRepository[]
  integrations     Integration[]
  aiConfig         UserAiConfig?
  ownedTeams       Team[]               @relation("TeamOwner")
  teamMemberships  TeamMember[]
  notifications    Notification[]
  reportSchedules  ReportSchedule[]
  calendarEvents   CalendarEvent[]
  emailPreference  EmailPreference?
  emailDeliveries  EmailDelivery[]
  trainingAttempts TrainingAttempt[]
  canvasTemplates  CanvasTemplate[]

  @@index([email])
  @@index([stripeCustomerId])
}

model CanvasTemplate {
  id               String   @id @default(cuid())
  name             String
  description      String?
  category         String   @default("methodology")
  // 'interviews' | 'focus_groups' | 'field_notes' | 'open_ended_survey'
  method           String?
  sampleQuestions  String // JSON: [{text, color}]
  sampleTranscript String
  sampleMemos      String? // JSON: [{title, content}]
  isPublic         Boolean  @default(true)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  creator          User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([name, createdBy])
  @@index([isPublic, category])
}

model UserAiConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  provider        String   @default("openai") // openai | anthropic | google
  apiKeyEncrypted String
  apiKeyIv        String
  apiKeyTag       String
  model           String?
  embeddingModel  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String // active | past_due | canceled | trialing
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DashboardAccess {
  id             String   @id @default(cuid())
  accessCode     String   @unique
  accessCodeHash String?
  name           String
  role           String // policymaker | funder | researcher
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  codingCanvases CodingCanvas[]
}

// ─── Coding Canvas ───

model CodingCanvas {
  id                String               @id @default(cuid())
  dashboardAccessId String
  userId            String?
  name              String
  description       String?
  ethicsApprovalId  String?
  ethicsStatus      String               @default("pending")
  dataRetentionDate DateTime?
  deletedAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  dashboardAccess   DashboardAccess      @relation(fields: [dashboardAccessId], references: [id], onDelete: Cascade)
  user              User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcripts       CanvasTranscript[]
  questions         CanvasQuestion[]
  memos             CanvasMemo[]
  codings           CanvasTextCoding[]
  nodePositions     CanvasNodePosition[]
  cases             CanvasCase[]
  relations         CanvasRelation[]
  computedNodes     CanvasComputedNode[]
  shares            CanvasShare[]
  consentRecords    ConsentRecord[]
  aiSuggestions     AiSuggestion[]
  fileUploads       FileUpload[]
  textEmbeddings    TextEmbedding[]
  chatMessages      ChatMessage[]
  summaries         Summary[]
  collaborators     CanvasCollaborator[]
  documents         CanvasDocument[]
  trainingDocuments TrainingDocument[]

  @@unique([dashboardAccessId, name])
  @@index([dashboardAccessId])
  @@index([userId])
  @@index([deletedAt])
}

model CanvasShare {
  id         String       @id @default(cuid())
  canvasId   String
  shareCode  String       @unique
  createdBy  String
  expiresAt  DateTime?
  cloneCount Int          @default(0)
  createdAt  DateTime     @default(now())
  canvas     CodingCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@index([canvasId])
  @@index([shareCode])
}

model CanvasTranscript {
  id            String             @id @default(cuid())
  canvasId      String
  title         String
  content       String
  sortOrder     Int                @default(0)
  caseId        String?
  sourceType    String?
  sourceId      String?
  deletedAt     DateTime?
  isAnonymized  Boolean            @default(false)
  participantId String?
  fileUploadId  String?
  timestamps    String? // JSON: [{start, end, text}]
  eventDate     DateTime?
  latitude      Float?
  longitude     Float?
  locationName  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  canvas        CodingCanvas       @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  case          CanvasCase?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  codings       CanvasTextCoding[]
  aiSuggestions AiSuggestion[]

  @@index([canvasId])
  @@index([caseId])
  @@index([deletedAt])
}

model CanvasQuestion {
  id               String             @id @default(cuid())
  canvasId         String
  text             String
  color            String             @default("#3B82F6")
  sortOrder        Int                @default(0)
  parentQuestionId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  canvas           CodingCanvas       @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  parentQuestion   CanvasQuestion?    @relation("QuestionHierarchy", fields: [parentQuestionId], references: [id], onDelete: SetNull)
  childQuestions   CanvasQuestion[]   @relation("QuestionHierarchy")
  codings          CanvasTextCoding[]

  @@index([canvasId])
  @@index([parentQuestionId])
}

model CanvasMemo {
  id        String       @id @default(cuid())
  canvasId  String
  title     String?
  content   String
  color     String       @default("#FEF08A")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  canvas    CodingCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)
}

model CanvasTextCoding {
  id           String           @id @default(cuid())
  canvasId     String
  transcriptId String
  questionId   String
  startOffset  Int
  endOffset    Int
  codedText    String
  note         String?
  annotation   String?
  createdAt    DateTime         @default(now())
  canvas       CodingCanvas     @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  transcript   CanvasTranscript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  question     CanvasQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([canvasId])
  @@index([transcriptId])
  @@index([questionId])
  @@index([canvasId, transcriptId])
}

model CanvasNodePosition {
  id        String       @id @default(cuid())
  canvasId  String
  nodeId    String
  nodeType  String
  x         Float
  y         Float
  width     Float?
  height    Float?
  collapsed Boolean      @default(false)
  canvas    CodingCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@unique([canvasId, nodeId])
  @@index([canvasId])
}

model CanvasCase {
  id          String             @id @default(cuid())
  canvasId    String
  name        String
  attributes  String             @default("{}")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  canvas      CodingCanvas       @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  transcripts CanvasTranscript[]

  @@unique([canvasId, name])
  @@index([canvasId])
}

model CanvasRelation {
  id        String       @id @default(cuid())
  canvasId  String
  fromType  String
  fromId    String
  toType    String
  toId      String
  label     String
  createdAt DateTime     @default(now())
  canvas    CodingCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@index([canvasId])
}

model CanvasComputedNode {
  id        String       @id @default(cuid())
  canvasId  String
  nodeType  String
  label     String
  config    String       @default("{}")
  result    String       @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  canvas    CodingCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@index([canvasId])
}

// ─── Ethics & Audit ───

model ConsentRecord {
  id             String       @id @default(cuid())
  canvasId       String
  participantId  String
  consentType    String       @default("informed")
  consentStatus  String       @default("active")
  consentDate    DateTime     @default(now())
  withdrawalDate DateTime?
  ethicsProtocol String?
  notes          String?
  createdAt      DateTime     @default(now())
  canvas         CodingCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@unique([canvasId, participantId])
  @@index([canvasId])
  @@index([participantId])
}

model AuditLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  action     String
  resource   String
  resourceId String?
  actorType  String
  actorId    String?
  ip         String?
  method     String?
  path       String?
  statusCode Int?
  meta       String?

  @@index([action])
  @@index([timestamp])
  @@index([actorId])
}

model WebhookEvent {
  id        String   @id // Stripe event ID
  type      String
  createdAt DateTime @default(now())
}

// ─── Collaboration ───

model CanvasCollaborator {
  id        String       @id @default(cuid())
  canvasId  String
  userId    String
  role      String       @default("editor") // owner | editor | viewer
  invitedBy String?
  createdAt DateTime     @default(now())
  canvas    CodingCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@unique([canvasId, userId])
  @@index([canvasId])
  @@index([userId])
}

// ─── Documents & Region Coding ───

model CanvasDocument {
  id            String                 @id @default(cuid())
  canvasId      String
  fileUploadId  String
  title         String
  docType       String // image | pdf
  pageCount     Int                    @default(1)
  metadata      String                 @default("{}")
  createdAt     DateTime               @default(now())
  canvas        CodingCanvas           @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  regionCodings DocumentRegionCoding[]

  @@index([canvasId])
}

model DocumentRegionCoding {
  id         String         @id @default(cuid())
  documentId String
  questionId String
  pageNumber Int            @default(1)
  x          Float // percentage 0-100
  y          Float
  width      Float
  height     Float
  note       String?
  createdAt  DateTime       @default(now())
  document   CanvasDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ─── Training Center ───

model TrainingDocument {
  id            String            @id @default(cuid())
  canvasId      String
  transcriptId  String
  name          String
  instructions  String?
  goldCodings   String // JSON: [{questionId, startOffset, endOffset, codedText}]
  passThreshold Float             @default(0.7)
  createdAt     DateTime          @default(now())
  canvas        CodingCanvas      @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  attempts      TrainingAttempt[]

  @@index([canvasId])
}

model TrainingAttempt {
  id                 String           @id @default(cuid())
  trainingDocumentId String
  userId             String?
  codings            String // JSON
  kappaScore         Float?
  passed             Boolean          @default(false)
  createdAt          DateTime         @default(now())
  trainingDocument   TrainingDocument @relation(fields: [trainingDocumentId], references: [id], onDelete: Cascade)
  user               User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trainingDocumentId])
  @@index([userId])
}

// ─── File Upload & Transcription ───

model FileUpload {
  id                String             @id @default(cuid())
  canvasId          String?
  userId            String?
  storageKey        String             @unique
  originalName      String
  mimeType          String
  sizeBytes         Int
  status            String             @default("uploaded") // uploaded | processing | ready | error
  metadata          String             @default("{}")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  canvas            CodingCanvas?      @relation(fields: [canvasId], references: [id], onDelete: SetNull)
  transcriptionJobs TranscriptionJob[]

  @@index([canvasId])
  @@index([storageKey])
}

model TranscriptionJob {
  id             String     @id @default(cuid())
  fileUploadId   String
  canvasId       String
  status         String     @default("queued") // queued | processing | completed | failed
  progress       Float      @default(0)
  resultText     String?
  resultSegments String? // JSON: [{start, end, text}]
  errorMessage   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  fileUpload     FileUpload @relation(fields: [fileUploadId], references: [id], onDelete: Cascade)

  @@index([canvasId])
  @@index([status])
}

// ─── Research Assistant ───

model TextEmbedding {
  id         String       @id @default(cuid())
  canvasId   String
  sourceType String // transcript_chunk | coding | memo
  sourceId   String
  chunkIndex Int          @default(0)
  chunkText  String
  embedding  String // JSON float array
  createdAt  DateTime     @default(now())
  canvas     CodingCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, chunkIndex])
  @@index([canvasId])
}

model ChatMessage {
  id        String       @id @default(cuid())
  canvasId  String
  userId    String?
  role      String // user | assistant
  content   String
  citations String       @default("[]") // JSON: [{sourceType, sourceId, text}]
  createdAt DateTime     @default(now())
  canvas    CodingCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@index([canvasId, createdAt])
}

model Summary {
  id          String       @id @default(cuid())
  canvasId    String
  sourceType  String // transcript | coding | question | canvas
  sourceId    String?
  summaryText String
  summaryType String       @default("paraphrase") // paraphrase | abstract | thematic
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  canvas      CodingCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@index([canvasId])
  @@index([sourceType, sourceId])
}

// ─── AI Features ───

model AiSuggestion {
  id            String           @id @default(cuid())
  canvasId      String
  transcriptId  String
  questionId    String?
  suggestedText String
  startOffset   Int
  endOffset     Int
  codedText     String
  confidence    Float            @default(0)
  status        String           @default("pending") // pending | accepted | rejected
  createdAt     DateTime         @default(now())
  canvas        CodingCanvas     @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  transcript    CanvasTranscript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  @@index([canvasId])
  @@index([transcriptId])
  @@index([status])
}

model AiUsage {
  id           String   @id @default(cuid())
  userId       String?
  canvasId     String?
  feature      String // suggest_codes | auto_code | summarize | chat | transcribe
  provider     String // openai | anthropic
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costCents    Float    @default(0)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Research Repository ───

model ResearchRepository {
  id          String              @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime            @default(now())
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  insights    RepositoryInsight[]

  @@unique([userId, name])
}

model RepositoryInsight {
  id           String             @id @default(cuid())
  repositoryId String
  canvasId     String?
  title        String
  content      String
  tags         String             @default("[]")
  sourceType   String?
  sourceId     String?
  createdAt    DateTime           @default(now())
  repository   ResearchRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
}

// ─── Integrations ───

model Integration {
  id              String    @id @default(cuid())
  userId          String
  provider        String // zoom | slack | qualtrics
  // Tokens are AES-256-GCM encrypted (see utils/encryption.ts).
  // accessToken / refreshToken hold the base64 ciphertext; the matching
  // Iv / Tag fields are required to decrypt.
  accessToken     String
  accessTokenIv   String?
  accessTokenTag  String?
  refreshToken    String?
  refreshTokenIv  String?
  refreshTokenTag String?
  metadata        String    @default("{}")
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// ─── Notifications ───

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // coding_added, canvas_shared, team_invite, comment, mention
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  String   @default("{}") // JSON: canvasId, actorName, etc.
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─── Report Schedules ───

model ReportSchedule {
  id        String    @id @default(cuid())
  userId    String
  canvasId  String?
  teamId    String?
  frequency String    @default("weekly") // daily, weekly, monthly
  dayOfWeek Int?      @default(1) // 0=Sun, 1=Mon, etc.
  lastSent  DateTime?
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([teamId])
  @@index([enabled, lastSent])
}

// ─── Lifecycle Email & Engagement ───

model EmailPreference {
  id               String    @id @default(cuid())
  userId           String    @unique
  lifecycle        Boolean   @default(true)
  productUpdates   Boolean   @default(true)
  trainingTips     Boolean   @default(true)
  inactivityNudges Boolean   @default(true)
  unsubscribeToken String    @unique
  unsubscribedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([unsubscribeToken])
}

model EmailCampaign {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  subject     String
  previewText String?
  bodyHtml    String
  ctaLabel    String?
  ctaUrl      String?
  audience    String          @default("all") // all, free, pro, team, inactive_14d, inactive_30d
  status      String          @default("draft") // draft, sent
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  sentAt      DateTime?
  deliveries  EmailDelivery[]

  @@index([status])
  @@index([audience])
}

model EmailDelivery {
  id         String         @id @default(cuid())
  userId     String
  campaignId String?
  type       String // welcome, onboarding_7d, inactivity_14d, product_update, training_tip
  eventKey   String
  subject    String
  status     String         @default("pending") // pending, sent, skipped, failed
  error      String?
  metadata   String         @default("{}")
  createdAt  DateTime       @default(now())
  sentAt     DateTime?
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign   EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([userId, eventKey])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([type])
  @@index([campaignId])
}

// ─── Teams ───

model Team {
  id              String           @id @default(cuid())
  name            String
  ownerId         String
  owner           User             @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members         TeamMember[]
  reportSchedules ReportSchedule[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([ownerId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("member") // owner, admin, member
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// ─── Calendar Events ───

model CalendarEvent {
  id          String    @id @default(cuid())
  userId      String
  canvasId    String?
  teamId      String?
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  type        String    @default("milestone") // milestone, deadline, session, review
  color       String?
  reminder    Int? // minutes before event
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@index([canvasId])
}
