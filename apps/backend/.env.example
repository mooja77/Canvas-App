# Database — PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/canvas_app
# Railway: provided automatically when you add a PostgreSQL plugin
DATABASE_URL="postgresql://user:password@localhost:5432/canvas_app"

# JWT secret — REQUIRED in production. Use a strong random string (32+ chars).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_ME_IN_PRODUCTION"

# Server port
PORT=3007

# Environment: "development" or "production"
NODE_ENV=development

# CORS / CSRF — comma-separated list of allowed frontend origins (required in production)
# Example: ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
# ALLOWED_ORIGINS=

# Registration gating — set to "true" to allow public account creation in production
# When false (default), registration is disabled in production
# REGISTRATION_ENABLED=false

# Optional: specific CORS origin and frontend URL
# CORS_ORIGIN=https://app.example.com
# FRONTEND_URL=https://app.example.com

# ─── Stripe / Billing ───
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_ACADEMIC_COUPON_ID=

# ─── App URL (for Stripe redirects and password reset links) ───
# APP_URL=http://localhost:5174

# ─── Email (SMTP) ───
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_...
# SMTP_FROM=Canvas App <noreply@yourdomain.com>

# ─── AI / LLM (optional server-side fallback — users bring their own keys) ───
# OPENAI_API_KEY=sk-...          # Optional fallback for legacy users / transcription
# AI_MODEL=gpt-4o-mini

# ─── Encryption (required for storing user API keys) ───
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# ─── File Storage (S3/R2/MinIO — omit for local fallback) ───
# S3_BUCKET=canvas-app-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_ENDPOINT=          # optional for R2/MinIO
