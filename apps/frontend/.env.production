# API is served from a subdomain of qualcanvas.com so the httpOnly auth cookie
# is FIRST-PARTY (same registrable domain as the frontend). Do NOT point this at
# the raw *.up.railway.app host — that makes the cookie third-party, which Safari
# (and Firefox/Brave/Chrome-incognito) block by default, locking those users out.
# api.qualcanvas.com is a CNAME → the Railway service. See PR for DNS setup.
VITE_API_URL=https://api.qualcanvas.com/api
