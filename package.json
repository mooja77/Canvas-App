{
  "name": "qualcanvas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone Qualitative Coding Canvas",
  "workspaces": [
    "shared",
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev": "npm run build -w shared && concurrently \"npm run dev -w apps/backend\" \"npm run dev -w apps/frontend\"",
    "dev:frontend": "npm run dev -w apps/frontend",
    "dev:backend": "npm run dev -w apps/backend",
    "build": "npm run build -w shared && npm run build -w apps/backend && npm run build -w apps/frontend",
    "build:budget": "node scripts/check-bundle-size.mjs",
    "start": "cd apps/backend && npm start",
    "db:migrate": "npm run db:migrate -w apps/backend",
    "db:seed": "npm run db:seed -w apps/backend",
    "lint": "eslint apps/backend/src apps/frontend/src shared",
    "lint:fix": "eslint --fix apps/backend/src apps/frontend/src shared",
    "format": "prettier --write \"apps/**/*.{ts,tsx}\" \"shared/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx}\" \"shared/**/*.ts\"",
    "test": "npm run test -w apps/backend && npm run test -w apps/frontend",
    "test:e2e": "npx playwright test --project=setup --project=chromium",
    "test:e2e:all": "npx playwright test",
    "test:e2e:firefox": "npx playwright test --project=setup --project=firefox",
    "test:e2e:webkit": "npx playwright test --project=setup --project=webkit",
    "test:e2e:mobile": "npx playwright test --project=setup --project=mobile-chrome --project=mobile-safari",
    "typecheck": "tsc -b apps/backend apps/frontend",
    "smoke-test": "bash scripts/smoke-test.sh",
    "smoke:postdeploy": "node scripts/post-deploy-smoke.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vite-plugin-pwa": "^0.21.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  }
}
