# ─── Canvas App Environment Variables ───
# Copy this file to .env and fill in the values.

# ─── Server ───
NODE_ENV=development
PORT=3007

# ─── Database ───
# PostgreSQL connection string (use file: for SQLite in dev)
DATABASE_URL=postgresql://canvas:your_password@localhost:5432/canvas_app

# ─── Auth ───
# Secret key for signing JWTs (use a long random string)
JWT_SECRET=change-me-to-a-random-secret

# 32-byte hex key for encrypting sensitive data (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# Google OAuth client ID (optional, enables Google sign-in)
GOOGLE_CLIENT_ID=

# Set to "true" to allow new user registration in production
REGISTRATION_ENABLED=false

# ─── CORS / Origins ───
# Comma-separated list of allowed origins for CORS and CSRF (production only)
ALLOWED_ORIGINS=https://your-domain.com
# Alternative origin variables (also checked by CSRF middleware)
CORS_ORIGIN=
FRONTEND_URL=

# ─── Application URL ───
# Used for Stripe redirects and password reset links
APP_URL=http://localhost:5174

# ─── Stripe / Billing ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe coupon ID for 40% academic discount (.edu emails)
STRIPE_ACADEMIC_COUPON_ID=

# ─── Email (SMTP) ───
# Required for password reset emails. In dev, reset links are logged to console.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Canvas App <noreply@example.com>

# ─── AI / LLM (optional, for auto-coding) ───
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# ─── S3 Storage (optional, defaults to local file storage) ───
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ─── Frontend (Vite) ───
# These must be prefixed with VITE_ to be available in the browser.
VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=

# Stripe price IDs for the pricing page
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=price_...
VITE_STRIPE_TEAM_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_TEAM_ANNUAL_PRICE_ID=price_...
